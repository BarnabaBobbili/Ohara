# Core
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# PostgreSQL (Neon)
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
# Use a direct (non-pooler) URL for Prisma migrate commands.
DIRECT_DATABASE_URL=postgresql://<user>:<password>@<direct-host>/<db>?sslmode=require
# Optional override name used by prisma.config.ts for migrations.
PRISMA_MIGRATE_DATABASE_URL=
# Optional shadow DB URL for local migrate diffing.
SHADOW_DATABASE_URL=
PG_POOL_MAX=24
PG_POOL_MIN=2
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000
PG_MAX_USES=7500

# MongoDB (Activity Logs)
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>/<db>
MONGODB_DB_NAME=LMS
MONGO_POOL_MAX=30
MONGO_POOL_MIN=2
ACTIVITY_LOG_MAX_LIMIT=200
ACTIVITY_LOG_MAX_SKIP=5000
ACTIVITY_COUNT_CACHE_MS=15000

# MySQL (Audit Trail)
MYSQL_HOST=<host>
MYSQL_PORT=3306
MYSQL_USER=<user>
MYSQL_PASSWORD=<password>
MYSQL_DATABASE=<db>
MYSQL_POOL_MAX=20
MYSQL_POOL_QUEUE_LIMIT=0
MYSQL_CONNECT_TIMEOUT_MS=8000
AUDIT_MAX_LIMIT=200

# Neo4j
NEO4J_URI=neo4j+s://<host>
NEO4J_USER=neo4j
NEO4J_PASSWORD=<password>

# Cache/Queue tuning
DASHBOARD_CACHE_MS=15000
REPORTS_CACHE_MS=30000
EXTERNAL_SEARCH_CACHE_MS=120000
LOG_QUEUE_MAX_SIZE=5000
LOG_QUEUE_CONCURRENCY=2
LOG_QUEUE_RETRY_LIMIT=2
LOG_QUEUE_RETRY_DELAY_MS=200
